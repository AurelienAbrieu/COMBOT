# Environment configuration
# Copy to .env and fill in values

APP_ENV=local
APP_SESSION_SECRET=

# PMD API
PMD_API_BASE_URL=https://api-uat.us.parcelpending.com
PMD_LOGIN=
PMD_PASSWORD=

# AWS Bedrock
AWS_BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
AWS_REGION=us-east-1

# Logging
APP_LOG_LEVEL=INFO
APP_LOG_TO_STDOUT=true

# GitLab (for release pipeline)
GITLAB_TOKEN=
